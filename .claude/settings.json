{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(git push:*)",
      "Bash(git rev-list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npx prisma:*)",
      "Bash(npx tsc:*)",
      "Bash(npx shadcn:*)"
    ]
  }
}
