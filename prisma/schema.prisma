generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// System-level role keys. Custom roles have key = null.
enum TaxTemplateStatus {
  DRAFT
  READY
}

enum TaxFieldKind {
  SINGLE
  SERIES
}

enum FinancialValueType {
  CURRENCY
  NUMBER
  PERCENT
  INTEGER
  DATE
  BOOLEAN
}

enum FinancialValueSource {
  OCR
  MANUAL
}

enum FinancialYearMode {
  REFERENCE
  PRIOR_1
  PRIOR_2
  PRIOR_3
}

enum RoleKey {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
  COLLABORATOR
  SUPPLIER
  CUSTOMER
}

enum Provider {
  EMAIL
  GOOGLE
  MICROSOFT
}

model Role {
  id          String           @id @default(cuid())
  key         RoleKey?         @unique
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  order       Int              @default(0)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([order])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  resource    String
  action      String
  description String?
  order       Int              @default(0)
  roles       RolePermission[]
  createdAt   DateTime         @default(now())

  @@index([resource, order])
}

model RolePermission {
  roleId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  passwordHash     String?
  emailVerified    DateTime?
  name             String?
  image            String?
  isActive         Boolean       @default(true)
  locale           String        @default("el")
  preferredLocales String[]      @default(["el"])
  roleId           String
  role          Role          @relation(fields: [roleId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  otpTokens     OtpToken[]
  excelImports  ExcelImport[]

  @@index([roleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String   // e.g. "users.create", "roles.delete", "auth.login"
  resource   String   // e.g. "user", "role"
  resourceId String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([resource, resourceId])
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  category    String   @default("general")
  description String?
  isSecret    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@index([category])
}

model DbBackup {
  id           String   @id @default(cuid())
  filename     String
  storageKey   String   @unique
  sizeBytes    BigInt
  status       String   @default("READY") // PENDING | READY | FAILED | RESTORING
  trigger      String   @default("cron")  // cron | manual
  errorMessage String?
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model MediaFolder {
  id        String         @id @default(cuid())
  name      String
  parentId  String?
  parent    MediaFolder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[]  @relation("FolderTree")
  files     MediaFile[]
  order     Int            @default(0)
  createdById String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([parentId])
  @@unique([parentId, name])
}

model MediaFile {
  id            String       @id @default(cuid())
  folderId      String?
  folder        MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name          String       // user-facing filename
  originalName  String       // upload-time original
  storageKey    String       @unique  // path on Bunny S3 (e.g. media/2025/12/abc-photo.webp)
  originalKey   String?      // for SVG: path of original .svg companion
  mimeType      String
  size          Int          // bytes
  width         Int?
  height        Int?
  isImage       Boolean      @default(false)
  isSvg         Boolean      @default(false)
  publicUrl     String       // CDN URL for primary file
  originalUrl   String?      // CDN URL for SVG original (when isSvg)
  uploadedById  String?
  uploadedAt    DateTime     @default(now())

  @@index([folderId])
  @@index([uploadedAt])
}

// ============================================================
// Companies (SoftOne TRDR-inspired: unified Customer / Supplier / Partner)
// ============================================================

model CompanyType {
  id          String                    @id @default(cuid())
  key         String                    @unique           // e.g. CUSTOMER, SUPPLIER, PARTNER, PROSPECT
  name        String                                      // display name (Greek), e.g. "Πελάτης"
  pluralName  String?                                     // "Πελάτες"
  description String?
  color       String?                   // hex, for badge
  icon        String?                   // react-icons key (e.g. "FiUser")
  isSystem    Boolean                   @default(false)   // CUSTOMER/SUPPLIER/PARTNER seeded as system
  order       Int                       @default(0)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  companies   CompanyTypeAssignment[]

  @@index([order])
}

model Company {
  id              String                  @id @default(cuid())
  // SoftOne TRDR identity
  code            String?                 @unique           // TRDR.CODE — internal code
  sodtype         Int?                                      // SoftOne sodtype (13=customer, 12=supplier...) (optional, informative)
  name            String                                    // TRDR.NAME — επωνυμία
  shortName       String?                                   // brand / σύντομη επωνυμία
  // Tax / legal
  afm             String?                 @unique           // ΑΦΜ / VAT number
  doy             String?                                   // ΔΟΥ / tax office
  irsData         String?                                   // additional IRS notes
  profession      String?                                   // επάγγελμα / activity
  legalForm       String?                                   // νομική μορφή (Α.Ε., Ι.Κ.Ε., κ.λπ.)
  gemhNumber      String?                                   // αρ. ΓΕΜΗ
  // Contact
  address         String?
  city            String?
  zip             String?
  country         String?                 @default("GR")
  district        String?
  phone           String?
  phone2          String?
  fax             String?
  email           String?
  website         String?
  contactPerson   String?
  contactTitle    String?
  // Financial
  iban            String?
  bankName        String?
  currency        String?                 @default("EUR")
  paymentTerms    String?
  creditLimit     Decimal?                @db.Decimal(14, 2)
  balance         Decimal?                @db.Decimal(14, 2)
  discount        Decimal?                @db.Decimal(5, 2)
  vatCategory     String?
  // Classification
  category        String?
  branchInfo      String?
  notes           String?
  // State
  isActive        Boolean                 @default(true)
  // ΑΕΔΕΕ extras
  foundingDate    DateTime?                                 // ημερομηνία ίδρυσης (regist_date)
  aadeStatus      String?                                   // deactivation_flag_descr (π.χ. ΕΝΕΡΓΟΣ ΑΦΜ)
  aadeFirmKind    String?                                   // firm_flag_descr (π.χ. ΕΠΙΤΗΔΕΥΜΑΤΙΑΣ)
  aadeSyncedAt    DateTime?
  // Logo (Bunny CDN)
  logoUrl         String?
  logoStorageKey  String?
  // ΓΕΜΗ extras
  arGemi              String?   @unique                     // Αριθμός ΓΕΜΗ (από Open Data) — string γιατί ξεπερνά Int32
  gemiOffice          String?                                // Τοπική Υπηρεσία ΓΕΜΗ
  gemiStatus          String?                                // Κατάσταση επιχείρησης (ΓΕΜΗ)
  gemiObjective       String?                                // Σκοπός εταιρείας
  gemiIsBranch        Boolean?                               // Υποκατάστημα ή Μητρική
  gemiAutoRegistered  Boolean?                               // Ολοκληρωμένη αυτοαπογραφή
  gemiLastStatusChange DateTime?
  gemiSyncedAt        DateTime?
  gemiData            Json?                                  // raw GEMI response για future-proofing
  // SoftOne sync
  s1Trdr          Int?                    @unique           // mirror TRDR primary key when synced
  s1UpdDate       DateTime?
  // Geocoding (MapTiler)
  latitude        Float?
  longitude       Float?
  geocodedAt      DateTime?
  geocodedAddress String?                                    // canonical address returned by geocoder
  // Audit
  createdById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  // FK to lookup tables (nullable; text counterparts above act as denormalized cache)
  legalTypeId          Int?
  legalTypeRef         LegalType?        @relation(fields: [legalTypeId], references: [id])
  businessTypeId       String?
  businessType         BusinessType?     @relation(fields: [businessTypeId], references: [id], onDelete: SetNull)
  businessTypeOverride Boolean           @default(false)
  gemiOfficeId      Int?
  gemiOfficeRef     GemiOfficeRef?    @relation(fields: [gemiOfficeId], references: [id])
  companyStatusId   Int?
  companyStatusRef  CompanyStatusRef? @relation(fields: [companyStatusId], references: [id])
  prefectureId      String?
  prefectureRef     Prefecture?       @relation(fields: [prefectureId], references: [id])
  municipalityId    String?
  municipalityRef   Municipality?     @relation(fields: [municipalityId], references: [id])
  regionCode        String?
  regionRef         Region?           @relation("CompanyRegion", fields: [regionCode], references: [code])
  vatCategoryId     Int?
  vatCategoryRef    VatCategory?      @relation(fields: [vatCategoryId], references: [id])

  // Manual operational data (όχι από API)
  employeeCount     Int?                                  // αριθμός εργαζομένων

  types           CompanyTypeAssignment[]
  branches        CompanyBranch[]
  activities      CompanyActivity[]
  documents       CompanyDocument[]
  contacts        CompanyContact[]
  channels        CompanyChannel[]
  assessments     CompanyAssessment[]
  financialValues CompanyFinancialValue[]
  ocrDocuments    OcrDocument[]

  @@index([legalTypeId])
  @@index([businessTypeId])
  @@index([gemiOfficeId])
  @@index([companyStatusId])
  @@index([prefectureId])
  @@index([municipalityId])
  @@index([regionCode])
  @@index([vatCategoryId])

  @@index([name])
  @@index([afm])
  @@index([isActive])
}

// ============================================================
// Reference / lookup tables — seeded from ΓΕΜΗ Open Data /metadata/*
// ============================================================

model LegalType {
  id          Int      @id            // GEMI legalType.id
  descr       String
  descrEn     String?
  lastUpdated DateTime?
  companies   Company[]
}

model GemiOfficeRef {
  id          Int      @id            // GEMI gemiOffice.id
  descr       String
  descrEn     String?
  address     String?
  city        String?
  zipCode     String?
  phone       String?
  fax         String?
  url         String?
  lastUpdated DateTime?
  companies   Company[]
}

model CompanyStatusRef {
  id          Int      @id            // GEMI status.id
  descr       String
  descrEn     String?
  isActive    Boolean  @default(true)
  lastUpdated DateTime?
  companies   Company[]
}

model Prefecture {
  id            String   @id          // GEMI prefecture.id (string in API)
  descr         String
  descrEn       String?
  lastUpdated   DateTime?
  municipalities Municipality[]
  companies     Company[]
}

// ΦΠΑ καθεστώτα/κατηγορίες — manual seed (όχι από ΓΕΜΗ).
model VatCategory {
  id          Int       @id @default(autoincrement())
  code        String    @unique          // π.χ. "NORMAL", "REDUCED", "EXEMPT", "ZERO"
  descr       String                     // "Κανονικό", "Μειωμένο", "Απαλλασσόμενο"…
  rate        Float?                     // π.χ. 24, 13, 6, 0 (nullable: για καθεστώτα χωρίς ποσοστό)
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  companies   Company[]

  @@index([order])
}

// Τύποι παραστατικών αγορών — σειρές (SERIES) της ενότητας Αγορών (PURDOC) από SoftOne.
model PurchaseDocType {
  id        Int      @id @default(autoincrement())
  code      String   @unique          // SoftOne SERIES (αριθμός σειράς)
  abbrev    String?                   // CODE (σύντμηση)
  name      String                    // NAME (Περιγραφή)
  section   String?                   // Υποενότητα (SOREDIR)
  isActive  Boolean  @default(true)
  order     Int      @default(0)

  @@index([order])
}

// Πελάτες (TRDR SODTYPE=13) από SoftOne via GetTable — μητρώο αναφοράς.
model SoftoneCustomer {
  id         Int     @id @default(autoincrement())
  trdr       Int     @unique           // SoftOne TRDR id
  code       String                    // CODE (κωδικός)
  name       String                    // NAME (επωνυμία)
  kind       String?                   // Πελάτης/Προμηθευτής/Πιστωτής (SODTYPE)
  afm        String?                   // Α.Φ.Μ.
  doy        String?                   // IRSDATA (Δ.Ο.Υ.)
  profession String?                   // JOBTYPETRD (επάγγελμα)
  address    String?
  district   String?
  zip        String?
  city       String?
  phone      String?                   // PHONE01
  phone2     String?                   // PHONE02
  fax        String?
  email      String?
  webpage    String?
  isActive   Boolean @default(true)

  @@index([name])
  @@index([code])
  @@index([afm])
}

// Προμηθευτές (TRDR SODTYPE=12) από SoftOne via GetTable — μητρώο αναφοράς.
model SoftoneSupplier {
  id         Int     @id @default(autoincrement())
  trdr       Int     @unique           // SoftOne TRDR id
  code       String                    // CODE (κωδικός)
  name       String                    // NAME (επωνυμία)
  kind       String?                   // Πελάτης/Προμηθευτής/Πιστωτής (SODTYPE)
  afm        String?                   // Α.Φ.Μ.
  doy        String?                   // IRSDATA (Δ.Ο.Υ.)
  profession String?                   // JOBTYPETRD (επάγγελμα)
  address    String?
  district   String?
  zip        String?
  city       String?
  phone      String?                   // PHONE01
  phone2     String?                   // PHONE02
  fax        String?
  email      String?
  webpage    String?
  isActive   Boolean @default(true)

  @@index([name])
  @@index([code])
  @@index([afm])
}

// Είδη & Υπηρεσίες (MTRL SODTYPE 51=είδος, 52=υπηρεσία) από SoftOne via GetTable.
model SoftoneItem {
  id         Int     @id @default(autoincrement())
  mtrl       Int     @unique           // SoftOne MTRL id
  code       String                    // CODE (κύριος κωδικός)
  code1      String?                   // CODE1 (Barcode / EAN)
  code2      String?                   // CODE2 (Κωδ. εργοστασίου)
  name       String                    // NAME (περιγραφή)
  name2      String?                   // NAME1 (περιγραφή 2)
  price      Float?                    // PRICER (λιανικής)
  isService  Boolean @default(false)   // SODTYPE=52
  isActive   Boolean @default(true)

  @@index([name])
  @@index([code])
  @@index([code1])
  @@index([code2])
  @@index([isService])
}

// Γενικοί βοηθητικοί πίνακες SoftOne (ΦΠΑ, μονάδες, ομάδες, κατηγορίες, κατασκευαστές, μάρκες…)
// για combo boxes / γενική χρήση. kind = το όνομα του SoftOne πίνακα.
model SoftoneLookup {
  id    Int    @id @default(autoincrement())
  kind  String                // π.χ. VAT | MTRUNIT | MTRGROUP | MTRCATEGORY | MTRMANFCTR | MTRMARK
  code  String                // SoftOne id/code
  name  String                // περιγραφή (combo label)
  order Int    @default(0)

  @@unique([kind, code])
  @@index([kind])
}

model Municipality {
  id            String     @id        // GEMI municipality.id (string)
  prefectureId  String?
  prefecture    Prefecture? @relation(fields: [prefectureId], references: [id])
  descr         String
  descrEn       String?
  lastUpdated   DateTime?
  companies     Company[]

  @@index([prefectureId])
  @@index([descr])
}

// Καλλικράτης δενδροειδής δομή — seed από public/periferies-*.json (όχι GEMI).
model Region {
  code        String   @id            // "111" (Περιφ.), "11102" (Π.Ε./Νομός), "1110202" (Δήμος)
  nameEL      String
  nameEN      String?
  level       Int                      // 3=Περιφέρεια, 4=Περιφ. Ενότητα/Νομός, 5=Δήμος
  parentCode  String?
  parent      Region?  @relation("RegionHierarchy", fields: [parentCode], references: [code], onDelete: SetNull)
  children    Region[] @relation("RegionHierarchy")
  path        String?                  // "111>11102>1110202"
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies       Company[]       @relation("CompanyRegion")
  companyBranches CompanyBranch[] @relation("BranchRegion")

  @@index([parentCode])
  @@index([level])
  @@index([nameEL])
}

enum DocumentSource {
  GEMI
  MANUAL
}

enum DocumentKind {
  DECISION       // CompanyDocumentDecision (απόφαση οργάνου)
  PUBLICATION    // CompanyDocumentPublication (ΥΜΣ)
  OTHER
}

model CompanyDocument {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source        DocumentSource  @default(GEMI)
  kind          DocumentKind    @default(OTHER)
  title         String                                       // τίτλος (decisionSubject ή summary ή filename)
  // GEMI document metadata
  kak           String?                                      // Κωδικός Αριθμός Καταχώρισης
  assembly      String?                                      // είδος οργάνου
  summary       String?                                      // περίληψη
  decisionSubject String?
  dateAssemblyDecided  DateTime?
  dateAnnounced        DateTime?
  dateRegistrated      DateTime?
  applicationStatus String?
  // File on Bunny CDN
  sourceUrl     String?                                      // αρχική URL στο businessportal
  storageKey    String?                                      // path στο Bunny zone
  publicUrl     String?                                      // CDN URL
  mimeType      String?
  sizeBytes     Int?
  metadata      Json?                                        // raw GEMI item για debugging
  createdAt     DateTime        @default(now())

  @@index([companyId])
  @@index([kak])
  @@unique([companyId, kak])
}

// Master catalog of all ΚΑΔ codes (Greek Activity Code register).
// Auto-populated from ΑΕΔΕΕ lookups and used for mapping/search across companies.
model KadCode {
  code            String    @id                              // canonical with dots, π.χ. "43.21.00" ή "62.10.12.00"
  codeWithoutDots String?   @unique @db.VarChar(10)          // "43210000" (padded to 8 για NACE-level)
  description     String                                     // legacy alias of title (kept for backward compat)
  title           String?                                    // επίσημος τίτλος (από kad2025.json)
  level           Int?                                       // 1..7
  sector          String?   @db.VarChar(3)                   // π.χ. "Α", "ΣΤ"
  sectorLetter    String?   @db.VarChar(3)                   // same as sector — indexed for filtering
  parentCode      String?                                    // πατρικός ΚΑΔ (string FK to KadCode.code)
  parent          KadCode?  @relation("KadHierarchy", fields: [parentCode], references: [code], onDelete: SetNull)
  children        KadCode[] @relation("KadHierarchy")
  path            String?                                    // π.χ. "Α>01>01.1>01.11>01.11.1>01.11.11"
  category        String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customerKADs    CustomerKAD[]
  licenseRequirements KadLicenseRequirement[]

  @@index([title])
  @@index([description])
  @@index([parentCode])
  @@index([level])
  @@index([sectorLetter])
  @@index([codeWithoutDots])
}

model CustomerKAD {
  id            Int       @id @default(autoincrement())
  customerId    String                                       // Company.id (cuid)
  submittedKAD  String    @db.VarChar(20)
  resolvedKAD   String?   @db.VarChar(20)
  resolvedCode  KadCode?  @relation(fields: [resolvedKAD], references: [code], onDelete: SetNull)
  hierarchyJSON Json?
  status        String    @default("resolved")               // resolved | ambiguous | not_found
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerId])
  @@index([submittedKAD])
  @@index([resolvedKAD])
}

// Λίστα ΚΑΔ που απαιτούν Άδεια Λειτουργίας (και άλλους τύπους αδειών στο μέλλον).
// Seeded από public/NF BUSNESS.xlsx. Τα παιδιά κληρονομούν τον κανόνα μέσω inherited=true.
enum KadLicenseType {
  OPERATING_LICENSE   // Άδεια λειτουργίας
}

model KadLicenseRequirement {
  id               Int             @id @default(autoincrement())
  code             String          @db.VarChar(20)
  kadCode          KadCode         @relation(fields: [code], references: [code], onDelete: Cascade)
  licenseType      KadLicenseType  @default(OPERATING_LICENSE)
  inherited        Boolean         @default(false)   // true = το κληρονόμησε από parent ΚΑΔ
  sourceParentCode String?         @db.VarChar(20)   // ο ρητά αναφερόμενος γονέας (αν inherited)
  source           String          @default("NF BUSNESS")
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([code, licenseType])
  @@index([licenseType])
  @@index([inherited])
  @@index([sourceParentCode])
}

model KadImportLog {
  id            Int      @id @default(autoincrement())
  totalCodes    Int
  importedAt    DateTime @default(now())
  sourceVersion String   @default("2026")
  status        String   @default("completed")
  notes         String?
}

enum ActivityKind {
  PRIMARY      // ΚΥΡΙΑ (firm_act_kind = 1)
  SECONDARY    // ΔΕΥΤΕΡΕΥΟΥΣΑ (firm_act_kind = 2)
}

model CompanyActivity {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code            String       // ΚΑΔ canonical με τελείες (από KadCode), π.χ. "43.21.00"
  codeWithoutDots String?      // ΚΑΔ canonical χωρίς τελείες, π.χ. "432100"
  codeAade        String?      // ΚΑΔ ακριβώς όπως ήρθε από ΑΑΔΕ (firm_act_code), zero-padded 8-ψήφια, π.χ. "43210000"
  description     String       // firm_act_descr
  kind            ActivityKind @default(SECONDARY)
  order           Int          @default(0)
  createdAt       DateTime     @default(now())

  @@unique([companyId, code])
  @@index([companyId])
  @@index([codeWithoutDots])
  @@index([codeAade])
}

enum ChannelKind {
  EMAIL
  PHONE
  MOBILE
  FAX
  OTHER
}

// Πολλαπλά κανάλια επικοινωνίας ανά εταιρία (email/phone/mobile/fax) με τίτλο
// για το καθένα (π.χ. "Λογιστήριο", "Διοίκηση", "Hot line πωλήσεων").
model CompanyChannel {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kind        ChannelKind
  label       String?                              // τίτλος π.χ. "Λογιστήριο", "Hotline"
  value       String                               // η ίδια η τιμή (email ή αριθμός)
  isPrimary   Boolean     @default(false)
  isActive    Boolean     @default(true)
  notes       String?
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId, kind])
  @@index([value])
}

model CompanyContact {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Identity
  firstName     String?
  lastName      String?
  fullName      String                                       // derived/required (το γεμίζει ο client)
  role          String?                                      // περιγραφή (π.χ. "Λογιστής", "Διευθυντής Πωλήσεων")
  department    String?
  // Communication
  mobile        String?
  phone         String?
  email         String?
  fax           String?
  // Address (separate from company HQ — π.χ. λογιστής με δικό του γραφείο)
  address       String?
  city          String?
  zip           String?
  country       String?  @default("GR")
  // Misc
  isPrimary     Boolean  @default(false)                     // κύρια επαφή
  isActive      Boolean  @default(true)
  notes         String?
  order         Int      @default(0)
  avatarUrl         String?
  avatarStorageKey  String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([email])
  @@index([mobile])
}

model CompanyBranch {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code          String?                  // εσωτερικός κωδικός υποκαταστήματος
  s1Branch      Int?                     // SoftOne BRANCH κωδικός (όταν συγχρονίζεται)
  name          String                   // π.χ. "Έδρα", "Υποκατάστημα Θεσσαλονίκης"
  isHeadquarters Boolean @default(false)
  address       String?
  city          String?
  zip           String?
  country       String?  @default("GR")
  district      String?
  phone         String?
  phone2        String?
  fax           String?
  email         String?
  contactPerson String?
  notes         String?
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  latitude      Float?
  longitude     Float?
  geocodedAt    DateTime?
  regionCode    String?
  regionRef     Region?  @relation("BranchRegion", fields: [regionCode], references: [code])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([regionCode])
  @@unique([companyId, code])
}

model CompanyTypeAssignment {
  companyId String
  typeId    String
  assignedAt DateTime    @default(now())
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      CompanyType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@id([companyId, typeId])
  @@index([typeId])
}

model ExcelImport {
  id           String   @id @default(cuid())
  userId       String
  fileName     String
  uploadedAt   DateTime @default(now())
  mappedFields Json?
  status       String   @default("PENDING")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// OCR / Intelligent Document Extraction (DeepSeek)
// ============================================================

enum OcrDocType {
  INVOICE
  RECEIPT
  GENERAL_TEXT
}

enum OcrPdfSource {
  DIGITAL
  SCANNED
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OcrCategory {
  EXPENSE
  INVOICE_IN
  INVOICE_OUT
  RECEIPT
  CREDIT_NOTE
  PAYROLL
  TAX
  OTHER
}

enum OcrPostStatus {
  NONE
  PENDING
  POSTED
  FAILED
}

model OcrDocument {
  id            String        @id @default(cuid())
  fileName      String                              // user-facing display name
  originalName  String
  storageKey    String        @unique                // Bunny path (private zone path)
  publicUrl     String                                // CDN URL or signed URL
  mimeType      String
  size          Int                                   // bytes
  docType       OcrDocType
  pdfSource     OcrPdfSource?                         // only for PDFs
  language      String        @default("el")          // ISO code: el / en / de ...
  status        OcrStatus     @default(PENDING)
  rawText       String?       @db.Text                // pdf-parse output (DIGITAL path)
  extractedData Json?                                 // full structured payload returned by LLM
  errorMessage  String?       @db.Text
  model         String?                               // which DeepSeek model was used
  tokensUsed    Int?
  durationMs    Int?
  createdById   String?
  createdAt     DateTime      @default(now())
  completedAt   DateTime?
  // Thumbnail (small WebP preview) cached on Bunny CDN.
  thumbKey      String?
  thumbUrl      String?
  // Categorization + downstream posting state.
  category      OcrCategory?
  notes         String?       @db.Text
  postStatus    OcrPostStatus @default(NONE)
  postedAt      DateTime?
  postedRef     String?                                 // SoftOne FINDOC ref / external doc id
  postError     String?       @db.Text
  // SoftOne supplier match (issuer ΑΦΜ → TRDR SODTYPE=12), filled on extraction.
  softoneTrdr    Int?                                    // matched supplier TRDR id
  softoneCode    String?                                 // matched supplier CODE
  softoneName    String?                                 // matched supplier NAME
  softoneKind    String?                                 // Προμηθευτής / Πιστωτής (SODTYPE)
  softoneChecked DateTime?                               // when the SoftOne lookup ran (null = not yet)
  invoiceKind    String?                                 // DeepSeek: service | product | mixed
  // PURDOC duplicate check (supplier + αριθμός + ημ/νία already in SoftOne).
  softoneDocExists  Boolean?                              // true = πιθανό διπλό βρέθηκε
  softoneDocRef     String?                               // FINCODE του υπάρχοντος παραστατικού
  softoneDocChecked DateTime?
  // Reconciliation / εκκρεμότητα. The display status is *derived* (see lib/ocr/recon-status.ts);
  // reconOverride is the manual hybrid lock: null = auto, RESOLVED = ολοκληρώθηκε, IGNORED = αγνοήθηκε.
  reconOverride String?                                   // null | RESOLVED | IGNORED
  itemsTotal    Int?                                      // # invoice lines (persisted at correlation)
  itemsMatched  Int?                                      // # lines matched to SoftOne MTRL
  // Chosen SoftOne document SERIES (PurchaseDocType.code) for posting. Replaces the
  // old free-text "Τύπος παραστατικού" with the real SoftOne series.
  softoneSeries String?
  // Folder/batch this document belongs to (folder upload).
  batchId       String?
  batch         OcrBatch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  items         OcrInvoiceItem[]
  // Company & tax-template linkage
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  taxTemplateId String?
  taxTemplate   TaxFormTemplate? @relation(fields: [taxTemplateId], references: [id], onDelete: SetNull)
  fiscalYear    Int?

  @@index([status])
  @@index([docType])
  @@index([category])
  @@index([postStatus])
  @@index([createdAt])
  @@index([batchId])
  @@index([companyId])
}

// A folder/batch of uploaded documents processed together.
model OcrBatch {
  id          String        @id @default(cuid())
  name        String                                    // folder name
  docType     OcrDocType    @default(INVOICE)
  language    String        @default("el")
  createdById String?
  createdAt   DateTime      @default(now())
  documents   OcrDocument[]

  @@index([createdAt])
}

// ============================================================
// European funding programs (ΕΣΠΑ / EU calls) — separate OCR pipeline
// ============================================================

enum ProgramStatus {
  DRAFT       // newly extracted, not reviewed
  REVIEWING   // user is editing
  PUBLISHED   // finalized, visible to internal users
  ARCHIVED
}

enum ProgramExtractStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/**
 * Κανόνας επιλεξιμότητας ΚΑΔ — το PDF συχνά αναφέρει είτε λίστα επιλέξιμων
 * (allow-list) είτε λίστα εξαιρούμενων (deny-list), σπάνια και τα δύο.
 */
enum KadEligibilityRule {
  ALL_EXCEPT_LISTED   // Όλοι οι ΚΑΔ είναι επιλέξιμοι ΕΚΤΟΣ από αυτούς που έχει flag excluded=true
  ONLY_LISTED         // Επιλέξιμοι ΜΟΝΟ οι ρητά αναφερόμενοι (excluded=false)
  MIXED               // Συνδυασμός — υπάρχει λίστα επιλέξιμων αλλά και εξαιρέσεις
  UNSPECIFIED         // Το PDF δεν διευκρινίζει
}

model Program {
  id              String        @id @default(cuid())
  // Core fields
  title           String                                 // required, editable
  summary         String?       @db.Text
  // Source PDF (Bunny private)
  sourceFileName  String?
  storageKey      String?       @unique
  publicUrl       String?
  mimeType        String?
  size            Int?
  // Dates
  publicationDate DateTime?
  submissionStart DateTime?
  submissionEnd   DateTime?
  // Budget & funding
  totalBudget     Decimal?      @db.Decimal(18, 2)       // total project budget €
  fundingRate     Decimal?      @db.Decimal(5, 2)        // subsidy percentage (e.g. 50.00)
  durationMonths  Int?
  // Reference codes (e.g. ΕΣΠΑ 2021-2027 codes)
  referenceCode   String?
  // ΚΑΔ eligibility rule (how to interpret the kads[] list)
  kadRule         KadEligibilityRule @default(UNSPECIFIED)
  kadRuleNote     String?            @db.Text       // free-form explanation from PDF
  // Eligibility thresholds for the applicant company
  minEmployeesFte     Decimal?       @db.Decimal(10, 2)   // ελάχιστες ΕΜΕ (Ετήσιες Μονάδες Εργασίας)
  minOperationalYears Decimal?       @db.Decimal(5, 2)    // ελάχιστα έτη λειτουργίας / διαχειριστικές χρήσεις
  eligibilityNote     String?        @db.Text             // free-form summary of eligibility
  // Status (lifecycle for the user, not LLM)
  status          ProgramStatus @default(DRAFT)
  // Extraction metadata
  extractStatus   ProgramExtractStatus @default(PENDING)
  extractedData   Json?
  errorMessage    String?       @db.Text
  model           String?
  tokensUsed      Int?
  durationMs      Int?
  // Manual notes
  notes           String?       @db.Text
  // Audit
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  // Relations
  kads            ProgramKad[]
  expenseCats     ProgramExpenseCategory[]
  regions         ProgramRegion[]
  criteria        ProgramCriterion[]
  deadlines       ProgramDeadline[]
  phases          ProgramPhase[]
  legalForms      ProgramEligibleLegalForm[]
  bonuses         ProgramBonus[]
  files           ProgramFile[]
  questionnaire   ProgramQuestionnaire?
  assessments     CompanyAssessment[]
  requiredFields  ProgramRequiredField[]

  @@index([status])
  @@index([extractStatus])
  @@index([submissionEnd])
  @@index([createdAt])
}

model ProgramKad {
  id              String   @id @default(cuid())
  programId       String
  program         Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  code            String                                 // canonical dotted, e.g. "62.01.11"
  codeWithoutDots String?
  description     String?  @db.Text
  excluded        Boolean  @default(false)               // true ⇒ ΚΑΔ που ρητά εξαιρείται

  @@unique([programId, code])
  @@index([programId])
  @@index([code])
  @@index([excluded])
}

model ProgramExpenseCategory {
  id            String   @id @default(cuid())
  programId     String
  program       Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  name          String                                  // "Μισθολογικό κόστος", "Εξοπλισμός", etc.
  minAmount     Decimal? @db.Decimal(18, 2)             // absolute floor in €
  minPercentage Decimal? @db.Decimal(5, 2)              // floor as % of total budget
  maxAmount     Decimal? @db.Decimal(18, 2)             // absolute cap in €
  maxPercentage Decimal? @db.Decimal(5, 2)              // cap as % of total budget
  mandatory     Boolean  @default(false)                // υποχρεωτική κατηγορία δαπάνης
  notes         String?  @db.Text
  order         Int      @default(0)

  @@index([programId])
  @@index([mandatory])
}

enum ProgramBonusKind {
  TIME_BASED       // π.χ. +10% αν ολοκλήρωση σε ≤9 μήνες
  EMPLOYMENT       // π.χ. +5% για κάθε νέα θέση εργασίας
  SUSTAINABILITY   // π.χ. +5% για πράσινες δαπάνες
  WOMEN_LED        // π.χ. +5% για γυναικείες επιχειρήσεις
  YOUTH            // π.χ. +5% για επιχειρηματίες <30 ετών
  R_AND_D          // +X% για ερευνητικές δαπάνες
  OTHER
}

model ProgramBonus {
  id              String           @id @default(cuid())
  programId       String
  program         Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  kind            ProgramBonusKind @default(OTHER)
  name            String                                          // "Bonus γρήγορης ολοκλήρωσης"
  condition       String           @db.Text                       // "Ολοκλήρωση φυσικού αντικειμένου εντός 9 μηνών"
  bonusRate       Decimal?         @db.Decimal(5, 2)              // π.χ. 10.00 (= +10%)
  bonusAmount     Decimal?         @db.Decimal(18, 2)             // απόλυτο ποσό αν δίνεται
  order           Int              @default(0)

  @@index([programId])
}

enum ProgramFileKind {
  MAIN              // κύριος οδηγός / πρόσκληση
  ANNEX             // παράρτημα
  CLARIFICATION     // διευκρινίσεις / επικαιροποίηση
  AMENDMENT         // τροποποίηση
  OTHER
}

model ProgramFile {
  id          String          @id @default(cuid())
  programId   String
  program     Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  fileName    String
  storageKey  String          @unique
  publicUrl   String?
  mimeType    String
  size        Int
  kind        ProgramFileKind @default(OTHER)
  label       String?                                              // user-facing label
  uploadedAt  DateTime        @default(now())
  uploadedById String?

  @@index([programId])
  @@index([kind])
}

model ProgramEligibleLegalForm {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String                                       // "ΙΚΕ", "ΕΠΕ", "ΑΕ", "Ατομική", "ΟΕ", "ΕΕ" κλπ.
  notes     String?

  @@unique([programId, name])
  @@index([programId])
}

model ProgramRegion {
  id           String   @id @default(cuid())
  programId    String
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  name         String                                   // "Αττική", "Δυτική Ελλάδα", ...
  fundingRate  Decimal? @db.Decimal(5, 2)               // regional override of subsidy % (some programs vary)
  notes        String?

  @@index([programId])
}

model ProgramCriterion {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  order     Int      @default(0)

  @@index([programId])
}

model ProgramDeadline {
  id          String   @id @default(cuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  deadline    DateTime
  description String?
  order       Int      @default(0)

  @@index([programId])
}

// ============================================================
// Supporting documents — catalog, program phases, requirements
// ============================================================

/// Global catalog of supporting-document types (δικαιολογητικά), reused across all programs.
model DocumentType {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  category       String?
  requiresExpiry Boolean  @default(true)
  notifyExpiry   Boolean  @default(true)
  active         Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  categoryId     String?
  categoryRef    DocumentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  requirements PhaseDocumentRequirement[]

  @@index([active])
  @@index([categoryId])
}

/// Free-form phases of a program (e.g. Υποβολή → Ένταξη → Υλοποίηση → Ολοκλήρωση). No dates here.
model ProgramPhase {
  id              String   @id @default(cuid())
  programId       String
  program         Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  name            String
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  phaseTemplateId String?
  phaseTemplate   PhaseTemplate? @relation(fields: [phaseTemplateId], references: [id], onDelete: SetNull)

  requirements PhaseDocumentRequirement[]

  @@index([programId])
}

/// Which document types are required at which phase, and whether mandatory.
model PhaseDocumentRequirement {
  id             String       @id @default(cuid())
  phaseId        String
  phase          ProgramPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  documentTypeId String
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  mandatory      Boolean      @default(true)
  notes          String?
  appliesToAll   Boolean      @default(false)
  businessTypes  RequirementBusinessType[]

  @@unique([phaseId, documentTypeId])
  @@index([phaseId])
  @@index([documentTypeId])
}

model BusinessType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies    Company[]
  requirements RequirementBusinessType[]

  @@index([active])
  @@index([order])
}

model DocumentCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documentTypes DocumentType[]

  @@index([active])
}

model PhaseTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phases ProgramPhase[]

  @@index([active])
  @@index([order])
}

model RequirementBusinessType {
  id             String   @id @default(cuid())
  requirementId  String
  requirement    PhaseDocumentRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  businessTypeId String
  businessType   BusinessType @relation(fields: [businessTypeId], references: [id], onDelete: Cascade)

  @@unique([requirementId, businessTypeId])
  @@index([requirementId])
  @@index([businessTypeId])
}

// ============================================================
// AI usage & cost tracking (SUPER_ADMIN only)
// ============================================================

enum AiScope {
  OCR_TEXT          // DeepSeek text model on digital PDF
  OCR_VISION        // Gemini / VLM vision call (image or scanned PDF page)
  OCR_VISION_RETRY  // upgraded-model retry firing on missing-fields
  TRANSLATION       // DeepSeek translation
  TAX_FORM          // Tax-form field extraction via vision pipeline
  OTHER
}

model AiUsage {
  id           String   @id @default(cuid())
  scope        AiScope
  provider     String                              // "deepseek" | "gemini" | "openai" | ...
  model        String                              // "deepseek-chat" | "gemini-2.5-flash" | ...
  operation    String?                             // free-form (e.g. "ocr.invoice", "i18n.batch")
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  inputCost    Decimal? @db.Decimal(12, 6)         // USD
  outputCost   Decimal? @db.Decimal(12, 6)         // USD
  totalCost    Decimal? @db.Decimal(12, 6)         // USD
  durationMs   Int?
  userId       String?
  refType      String?                             // "OcrDocument" etc.
  refId        String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([scope])
  @@index([model])
  @@index([userId])
}

model OcrInvoiceItem {
  id          String      @id @default(cuid())
  documentId  String
  document    OcrDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  rowIndex    Int
  code        String?
  name        String
  quantity    Decimal?    @db.Decimal(18, 4)
  price       Decimal?    @db.Decimal(18, 4)
  discount    Decimal?    @db.Decimal(18, 4)
  vatRate     Decimal?    @db.Decimal(5, 2)
  total       Decimal?    @db.Decimal(18, 4)
  // SoftOne item match (filled by correlation; null = δεν βρέθηκε).
  softoneMtrl      Int?
  softoneCode      String?
  softoneName      String?
  softoneIsService Boolean?
  softoneMatchedBy String?                              // code2 | code1 | code | manual

  @@index([documentId])
  @@index([softoneMtrl])
}

model SupplierTemplate {
  id           String      @id @default(cuid())
  vatNumber    String
  docType      OcrDocType
  supplierName String?
  example      Json
  fieldHints   Json?
  sampleDocId  String?
  thumbUrl     String?
  timesUsed    Int      @default(0)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([vatNumber, docType])
  @@index([vatNumber])
}

model SupplierFieldRule {
  id           String     @id @default(cuid())
  vatNumber    String                 // issuer ΑΦΜ (normalized, 9 digits)
  docType      OcrDocType             // INVOICE | RECEIPT (never GENERAL_TEXT)
  key          String                 // stable machine key (slug) → extractedData.customFields[key]
  label        String                 // user-facing field name, e.g. "Αριθμός Παραγγελίας"
  description  String?    @db.Text     // instruction to the AI (what / where to look)
  regionHint   Json?                  // optional { page, bbox:[x,y,w,h] } from the 🎯 marker
  scope        String     @default("document")  // "document" | "line"
  valueType    String     @default("text")       // "text" | "list"
  isActive     Boolean    @default(true)
  supplierName String?                // denormalized for the list page
  timesUsed    Int        @default(0)
  createdById  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([vatNumber, docType, key])
  @@index([vatNumber, docType])
}

// ============================================================
// Tax-form templates, per-company financial values, program required fields
// ============================================================

model TaxFormTemplate {
  id               String   @id @default(cuid())
  code             String
  name             String
  year             Int?
  description      String?  @db.Text
  status           TaxTemplateStatus @default(DRAFT)
  sampleStorageKey String?
  samplePageCount  Int?
  sampleThumbUrl   String?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  fields           TaxFormTemplateField[]
  requiredBy       ProgramRequiredField[]
  documents        OcrDocument[]

  @@unique([code, year])
  @@index([status])
}

model TaxFormTemplateField {
  id          String   @id @default(cuid())
  templateId  String
  template    TaxFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey    String
  label       String
  section     String?
  valueType   FinancialValueType @default(CURRENCY)
  kind        TaxFieldKind @default(SINGLE)
  regionHint  Json?
  aiHint      String?  @db.Text
  required    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([templateId, fieldKey])
  @@index([templateId])
}

model CompanyFinancialValue {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fieldKey         String
  templateId       String?
  year             Int
  value            Decimal  @db.Decimal(18, 2)
  valueType        FinancialValueType
  source           FinancialValueSource @default(OCR)
  sourceDocumentId String?
  confidence       Float?
  verified         Boolean  @default(false)
  verifiedById     String?
  periodStart      DateTime?
  periodEnd        DateTime?
  validUntil       DateTime?
  note             String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([companyId, fieldKey, year])
  @@index([companyId])
  @@index([fieldKey, year])
}

model ProgramRequiredField {
  id          String   @id @default(cuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  templateId  String
  template    TaxFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey    String
  yearsBack   Int      @default(1)
  mandatory   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([programId, templateId, fieldKey])
  @@index([programId])
}

// ============================================================
// Self-assessment questionnaire (per Program) & company evaluation
// ============================================================

enum QuestionnaireScoringModel {
  WEIGHTED
  POINTS_SUM
}

enum QuestionnaireStatus {
  DRAFT
  READY
}

enum QuestionAnswerType {
  BOOLEAN
  SINGLE_CHOICE
  NUMERIC
  SCALE
}

enum AssessmentStatus {
  DRAFT
  COMPLETED
}

enum AssessmentVerdict {
  ELIGIBLE
  NOT_ELIGIBLE
  NEEDS_REVIEW
}

enum AnswerSource {
  AUTO
  MANUAL
}

model ProgramQuestionnaire {
  id             String   @id @default(cuid())
  programId      String   @unique
  program        Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  title          String?
  description    String?  @db.Text
  scoringModel   QuestionnaireScoringModel @default(WEIGHTED)
  threshold      Decimal? @db.Decimal(8, 2)
  maxScore       Decimal? @db.Decimal(8, 2)
  sourceNote     String?
  status         QuestionnaireStatus @default(DRAFT)
  generatedModel String?
  generatedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  questions      ProgramQuestion[]
  assessments    CompanyAssessment[]
}

model ProgramQuestion {
  id              String   @id @default(cuid())
  questionnaireId String
  questionnaire   ProgramQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  code            String?
  text            String   @db.Text
  criterionRef    String?
  helpText        String?  @db.Text
  answerType      QuestionAnswerType @default(SINGLE_CHOICE)
  weight          Decimal? @db.Decimal(8, 2)
  maxPoints       Decimal? @db.Decimal(8, 2)
  companyField    String?
  order           Int      @default(0)
  options         ProgramQuestionOption[]
  answers         AssessmentAnswer[]
  @@index([questionnaireId])
}

model ProgramQuestionOption {
  id          String  @id @default(cuid())
  questionId  String
  question    ProgramQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label       String
  points      Decimal @default(0) @db.Decimal(8, 2)
  order       Int     @default(0)
  @@index([questionId])
}

model CompanyAssessment {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  programId           String
  program             Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  questionnaireId     String?
  questionnaire       ProgramQuestionnaire? @relation(fields: [questionnaireId], references: [id], onDelete: SetNull)
  eligible            Boolean?
  eligibilityResult   Json?
  questionnaireScore  Decimal? @db.Decimal(8, 2)
  questionnaireMax    Decimal? @db.Decimal(8, 2)
  questionnairePassed Boolean?
  overallVerdict      AssessmentVerdict @default(NEEDS_REVIEW)
  status              AssessmentStatus  @default(DRAFT)
  notes               String?  @db.Text
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  answers             AssessmentAnswer[]
  @@index([companyId])
  @@index([programId])
  @@index([programId, eligible])
}

model AssessmentAnswer {
  id               String  @id @default(cuid())
  assessmentId     String
  assessment       CompanyAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId       String
  question         ProgramQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  valueBool        Boolean?
  valueNumber      Decimal? @db.Decimal(14, 4)
  valueText        String?  @db.Text
  selectedOptionId String?  // intentional loose ref (no FK): questionnaire regen full-replaces options; we keep historical answers
  pointsAwarded    Decimal? @db.Decimal(8, 2)
  source           AnswerSource @default(MANUAL)
  @@index([assessmentId])
  @@index([questionId])
}
